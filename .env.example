# =============================================================================
# CIC Inmuebles — variables de entorno
# Copia este archivo como `.env.local` y completa los valores.
# NUNCA subas `.env.local` al repositorio (ya está en .gitignore).
# El proyecto compila y funciona SIN estas variables (usa datos de ejemplo);
# se van conectando a medida que avanza la Fase 1.
# =============================================================================

# --- Sitio / contacto (públicas) ---------------------------------------------
NEXT_PUBLIC_SITE_URL="https://cicinmuebles.com"
NEXT_PUBLIC_CONTACT_EMAIL="cc.inmuebles@gmail.com"
# Número de WhatsApp en formato internacional SIN "+", solo dígitos (ej. Colombia)
NEXT_PUBLIC_WHATSAPP="573000000000"
NEXT_PUBLIC_PHONE_DISPLAY="+57 300 000 0000"
NEXT_PUBLIC_INSTAGRAM=""
NEXT_PUBLIC_FACEBOOK=""

# --- Correo de leads (Resend - capa gratuita) --------------------------------
# https://resend.com -> API Keys. Sin esta clave, los leads se registran en consola.
RESEND_API_KEY=""
RESEND_FROM="CIC Inmuebles <onboarding@resend.dev>"
# A dónde llegan las notificaciones de nuevos leads (por defecto el correo de contacto)
LEADS_NOTIFICATION_EMAIL="cc.inmuebles@gmail.com"

# --- Base de datos (Supabase) — se conecta en el siguiente paso de Fase 1 -----
# https://supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Clave de servicio (SOLO servidor, nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=""

# --- Imágenes (Cloudinary - capa gratuita) — Fase 1 medios -------------------
# https://cloudinary.com -> Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Preset de subida sin firmar (opcional, para subir desde el panel admin)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# --- Google Drive (archivo/respaldo) — Fase 2 --------------------------------
# Cuenta de servicio de Google Cloud con acceso al Drive de cc.inmuebles@gmail.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
# Carpeta raíz en Drive donde se crea una subcarpeta por inmueble
GOOGLE_DRIVE_ROOT_FOLDER_ID=""
