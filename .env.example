# =============================================================================
# CIC Inmuebles — variables de entorno
# Copia este archivo como `.env.local` y completa los valores.
# NUNCA subas `.env.local` al repositorio (ya está en .gitignore).
# El proyecto compila y funciona SIN estas variables (usa datos de ejemplo);
# se van conectando a medida que avanza la Fase 1.
# =============================================================================

# --- Sitio / contacto (públicas) ---------------------------------------------
NEXT_PUBLIC_SITE_URL="https://cicinmuebles.com"
NEXT_PUBLIC_CONTACT_EMAIL="cc.inmuebles@gmail.com"
# Número de WhatsApp en formato internacional SIN "+", solo dígitos (ej. Colombia)
NEXT_PUBLIC_WHATSAPP="573000000000"
NEXT_PUBLIC_PHONE_DISPLAY="+57 300 000 0000"
NEXT_PUBLIC_INSTAGRAM=""
NEXT_PUBLIC_FACEBOOK=""

# --- Correo de leads (Resend - capa gratuita) --------------------------------
# https://resend.com -> API Keys. Sin esta clave, los leads se registran en consola.
RESEND_API_KEY=""
RESEND_FROM="CIC Inmuebles <onboarding@resend.dev>"
# A dónde llegan las notificaciones de nuevos leads (por defecto el correo de contacto)
LEADS_NOTIFICATION_EMAIL="cc.inmuebles@gmail.com"

# --- Panel de administración (autenticación) --------------------------------
# Credenciales del admin (cámbialas en producción). Valores por defecto solo dev.
ADMIN_EMAIL="admin@cicinmuebles.com"
ADMIN_PASSWORD="cic-admin-2026"
# Secreto para firmar la cookie de sesión (usa una cadena larga y aleatoria)
ADMIN_SESSION_SECRET=""

# --- Base de datos (Supabase) — se conecta en el siguiente paso de Fase 1 -----
# https://supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Clave de servicio (SOLO servidor, nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=""

# --- Imágenes (Cloudinary - capa gratuita) — MOTOR VISUAL ÚNICO --------------
# https://cloudinary.com -> Dashboard. Todas las fotos del catálogo se sirven
# optimizadas desde Cloudinary (CDN), vengan del panel o de Google Drive.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Preset de subida SIN FIRMAR. Necesario tanto para subir desde el panel como
# para re-alojar en Cloudinary las fotos importadas de Drive. Créalo en
# Cloudinary -> Settings -> Upload -> Upload presets (Signing Mode: Unsigned).
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# --- Google Drive (archivo/respaldo) — Fase 2 --------------------------------
# Cuenta de servicio de Google Cloud con acceso al Drive de cc.inmuebles@gmail.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
# Carpeta raíz en Drive donde se crea una subcarpeta por inmueble
GOOGLE_DRIVE_ROOT_FOLDER_ID=""

# --- Catálogo en Google Sheets (misma cuenta de servicio) --------------------
# Crea una hoja, compártela con la cuenta de servicio como EDITOR y pega su ID
# (el tramo de la URL: docs.google.com/spreadsheets/d/<ESTE_ID>/edit).
# El inventario completo se sincroniza solo al crear/editar/eliminar inmuebles.
GOOGLE_SHEETS_SPREADSHEET_ID=""

# --- Sincronizacion automatica (Cron de Vercel) ------------------------------
# Secreto que protege el endpoint /api/cron/sync. Usa una cadena larga aleatoria.
# Vercel envia "Authorization: Bearer <CRON_SECRET>" al cron automaticamente.
CRON_SECRET=""
